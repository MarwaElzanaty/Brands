@model LocalBrands.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="container mt-4">
    <h2>@Model.Name</h2>
    <p class="text-muted">@Model.Description</p>

    <!-- Search by Brand -->
    <form asp-action="Details" method="get" class="mb-3">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="input-group">
            <input type="text" name="brandName" class="form-control" placeholder="Search by brand..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    <h4 class="mt-4">Products in this Category</h4>

    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="row">
            @foreach (var product in Model.Products)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(product.PictureUrl))
                        {
                            <img src="~/Images/@product.PictureUrl" class="card-img-top" alt="@product.Name" />
                        }
                        else
                        {
                            <img src="~/images/img10.jpg" class="card-img-top" alt="No image available" />
                        }

                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text">
                                <strong>Price:</strong> @product.Price <br />
                                <strong>Rating:</strong> @product.Rating
                            </p>
                        </div>
                        <div class="card-footer text-muted text-center">
                            Brand: @(product.Brand != null ? product.Brand.Name : "No Brand")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No products found for this category.</p>
    }
</div>