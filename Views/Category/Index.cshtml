@model IEnumerable<LocalBrands.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <h2 class="mb-3">Categories</h2>

    <ul class="list-group">
        @foreach (var category in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <a asp-action="Details" asp-route-id="@category.Id" class="text-decoration-none">
                    @category.Name
                </a>
                <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">
                    Delete
                </a>
            </li>
        }
    </ul>

    <div class="mt-3">
        <a asp-action="Create" class="btn btn-primary">Add New Category</a>
    </div>
</div>