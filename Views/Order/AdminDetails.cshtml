@model LocalBrands.Models.Order
@{
    ViewData["Title"] = "Order Details (Admin)";
}

<div class="container mt-5">
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">
                <i class="fa-solid fa-box-open me-2"></i> Order Details - ID: @Model.Id
            </h3>
            <a asp-action="AdminIndex" class="btn btn-light btn-sm fw-bold">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>

        <div class="card-body">
            <!-- User Info -->
            <h5 class="mb-3 text-secondary"><i class="fa-regular fa-user me-2"></i> User Information</h5>
            <div class="row mb-4">
                <div class="col-md-6"><div class="list-group-item"><strong>User Name:</strong> @Model.User?.UserName</div></div>
                <div class="col-md-6"><div class="list-group-item"><strong>Email:</strong> @Model.User?.Email</div></div>
            </div>

            <!-- Order Info -->
            <h5 class="mb-3 text-secondary"><i class="fa-solid fa-file-invoice me-2"></i> Order Information</h5>
            <div class="row mb-4">
                <div class="col-md-4"><div class="list-group-item"><strong>Date:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="col-md-4">
                    <div class="list-group-item">
                        <strong>Status:</strong>
                        <span class="badge @(Model.Status == "Pending" ? "bg-warning text-dark" :
                                               Model.Status == "Confirmed" ? "bg-info text-dark" :
                                               Model.Status == "Completed" ? "bg-success" : "bg-secondary")">
                            @Model.Status
                        </span>
                    </div>
                </div>
                <div class="col-md-4"><div class="list-group-item"><strong>Total Amount:</strong> @Model.TotalAmount.ToString("C")</div></div>
            </div>
            <div class="row mb-4">
                <div class="col-md-6"><div class="list-group-item"><strong>Shipping Address:</strong> @Model.ShippingAddress</div></div>
                <div class="col-md-3"><div class="list-group-item"><strong>Phone Number:</strong> @Model.PhoneNumber</div></div>
                <div class="col-md-3"><div class="list-group-item"><strong>Notes:</strong> @Model.Notes</div></div>
            </div>

            <!-- Payment Info -->
            @if (Model.Payment != null)
            {
                <h5 class="mb-3 text-secondary"><i class="fa-solid fa-credit-card me-2"></i> Payment Information</h5>
                <div class="row mb-4">
                    <div class="col-md-4"><div class="list-group-item"><strong>Amount:</strong> @Model.Payment.Amount.ToString("C")</div></div>
                    <div class="col-md-4"><div class="list-group-item"><strong>Date:</strong> @Model.Payment.PaymentDate?.ToString("dd/MM/yyyy HH:mm") ?? "No date"</div></div>
                    <div class="col-md-4"><div class="list-group-item"><strong>Method:</strong> @Model.Payment.Method ?? "No method"</div></div>
                </div>
            }

            <!-- Order Items -->
            <h5 class="mb-3 text-secondary"><i class="fa-solid fa-cart-shopping me-2"></i> Order Items</h5>
            <table class="table table-striped shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.Product.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.PriceAtPurchase.ToString("C")</td>
                            <td>@((item.PriceAtPurchase * item.Quantity).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <!-- Update Status -->
            <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
                <select name="status" class="form-select d-inline w-auto">
                    <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                    <option value="Confirmed" selected="@(Model.Status == "Confirmed")">Confirmed</option>
                    <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
                </select>
                <button type="submit" class="btn btn-info ms-2">
                    <i class="bi bi-check-circle"></i> Update Status
                </button>
            </form>

            <!-- Delete -->
            <form asp-action="AdminDelete" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
</div>