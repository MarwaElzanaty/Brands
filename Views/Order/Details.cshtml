@model LocalBrands.Models.Order
@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white">
            <h3>Order Details</h3>
        </div>
        <div class="card-body">
            <!-- Order Info -->
            <dl class="row">
                <dt class="col-sm-3">Order ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Order Date</dt>
                <dd class="col-sm-9">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Shipping Address</dt>
                <dd class="col-sm-9">@Model.ShippingAddress</dd>

                <dt class="col-sm-3">Phone Number</dt>
                <dd class="col-sm-9">@Model.PhoneNumber</dd>

                <dt class="col-sm-3">Notes</dt>
                <dd class="col-sm-9">@Model.Notes</dd>
            </dl>

            <!-- Order Items -->
            <h5 class="mt-4">Items</h5>
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.Product.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.PriceAtPurchase.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Total -->
            <div class="alert alert-info fw-bold">
                Total Amount: @Model.TotalAmount.ToString("C")
            </div>

            <!-- Payment Info -->
            @if (Model.Payment != null)
            {
                <h5 class="mt-4">Payment Information</h5>
                <dl class="row">
                    <dt class="col-sm-3">Method</dt>
                    <dd class="col-sm-9">@Model.Payment.Method</dd>

                    <dt class="col-sm-3">Amount</dt>
                    <dd class="col-sm-9">@Model.Payment.Amount.ToString("C")</dd>

                    <dt class="col-sm-3">Payment Date</dt>
                    <dd class="col-sm-9">@Model.Payment.PaymentDate?.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            }
            else
            {
                <div class="alert alert-warning">
                    Payment information not available.
                </div>
            }
        </div>
    </div>
</div>