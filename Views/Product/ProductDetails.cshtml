@model LocalBrands.ViewModels.ProductDetailsViewModel
@{
    ViewData["Title"] = "ProductDetails";
}
    @* Product Details *@
<div class="container mt-5">
    <h1 class="text-center mb-5 fw-bold">Product Details</h1>

    <div class="row gx-lg-5">
        @* القسم الأيسر: الصورة والمراجعات *@
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm overflow-hidden mb-4 rounded-4">
                <img src="~/images/@Model.Product.PictureUrl" class="img-fluid w-100"
                     alt="@Model.Product.Name" style="object-fit: cover; height:500px !important">
            </div>

            @* صندوق المراجعات *@
            <div class="reviews-section p-4 bg-light rounded-4 shadow-sm border-0" 
                 style="max-height: 450px; overflow-y: auto; scrollbar-width: thin;">
                
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom" 
                     style="position: sticky; top: 0; background-color: #f8f9fa; z-index: 10;">
                    <h5 class="fw-bold m-0 text-dark">
                        <i class="bi bi-chat-left-text me-2"></i>Customer Reviews 
                        <span class="badge bg-secondary ms-2 fs-6">@Model.Reviews.Count</span>
                    </h5>
                </div>

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var item in Model.Reviews)
                    {
                        <div class="review-card mb-3 p-3 bg-white rounded-3 shadow-sm border-start border-primary border-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="fw-bold mb-0 text-dark">@item.User.FirstName @item.User.LastName</h6>
                                    <small class="text-muted" style="font-size: 0.7rem;">
                                        <i class="bi bi-calendar3 me-1"></i>@item.CreatedAt.ToString("MMMM dd, yyyy")
                                    </small>
                                </div>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= item.Rating ? "bi-star-fill" : "bi-star") shadow-sm"></i>
                                    }
                                </div>
                            </div>
                            <p class="mb-0 text-secondary small" style="font-style: italic; line-height: 1.5;">
                                "@item.Content"
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="bi bi-emoji-neutral fs-1 text-muted"></i>
                        <p class="text-muted mt-2">No reviews yet for this product.</p>
                    </div>
                }

                @* فورم إضافة مراجعة - تظهر فقط لمن اشترى *@
                @if (Model.CanLeaveReview)
                {
                    <div class="add-review-section mt-4 p-3 bg-white rounded-3 shadow-sm border border-primary border-opacity-25">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-plus-circle me-2"></i>Add Your Review</h6>
                        <form asp-action="Add" asp-controller="Review" method="post">
                            <input type="hidden" name="ProductId" value="@Model.Product.Id" />
                            
                            <div class="mb-2">
                                <label class="small fw-bold text-muted">Rating:</label>
                                <select name="Rating" class="form-select form-select-sm">
                                    <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                    <option value="4">⭐⭐⭐⭐ (Very Good)</option>
                                    <option value="3">⭐⭐⭐ (Good)</option>
                                    <option value="2">⭐⭐ (Fair)</option>
                                    <option value="1">⭐ (Poor)</option>
                                </select>
                            </div>

                            <div class="mb-2">
                                <textarea name="Content" class="form-control form-control-sm" rows="2" placeholder="How was the product?" required></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold">Submit Review</button>
                        </form>
                    </div>
                }
            </div>
        </div>

        @* القسم الأيمن: تفاصيل المنتج *@
        <div class="col-md-6">
            <div class="product-details p-2">
                <h1 class="display-5 fw-bold mb-2">@Model.Product.Name</h1>
                <p class="badge bg-info text-dark mb-3">@Model.Product.Brand.Name</p>

                <div class="description-box mb-4">
                    <h6 class="fw-bold text-muted text-uppercase small">Description</h6>
                    <p class="text-dark" style="line-height: 1.6;">@Model.Product.Description</p>
                </div>
                
                <div class="d-flex align-items-center mb-4">
                    <span class="fs-3 fw-bold text-primary me-3">@Model.Product.Price.ToString("N2") EGP</span>
                    <span class="badge bg-light text-muted border p-2">
                        <i class="bi bi-bag-check me-1"></i>Sold: @Model.Product.SalesCount
                    </span>
                </div>

                <div class="rating-display mb-4">
                    <span class="text-warning fs-5">
                         @for (int i = 1; i <= 5; i++)
                         {
                             <i class="bi @(i <= Model.Product.Rating ? "bi-star-fill" : "bi-star")"></i>
                         }
                    </span>
                    <span class="ms-2 text-muted">(@Model.Product.Rating / 5)</span>
                </div>

                <form method="post" asp-action="UserCartCheck" asp-controller="Cart">
                    <div class="mt-5">
                        <div class="row g-2">
                            <div class="col-4">
                                <input type="hidden" name="ProductId" value="@Model.Product.Id" />
                                <div class="input-group border border-dark rounded-3 overflow-hidden">
                                    <button class="btn btn-light border-0" type="button" id="decrease">-</button>
                                    <input type="text" class="form-control border-0 text-center bg-transparent fw-bold" value="1" id="counter" name="Quantity">
                                    <button class="btn btn-light border-0" type="button" id="increase">+</button>
                                </div>
                            </div>
                            <div class="col-8">
                                <button type="submit" class="btn btn-dark w-100 py-2 fw-bold text-uppercase rounded-3 shadow">
                                    <i class="bi bi-cart-plus me-2"></i>Add to cart
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<script> 
    const counterInput = document.getElementById("counter");
const increaseBtn = document.getElementById("increase");
const decreaseBtn = document.getElementById("decrease"); 
increaseBtn.addEventListener("click", () => { counterInput.value = parseInt(counterInput.value) + 1; });
decreaseBtn.addEventListener("click", () => { let currentValue = parseInt(counterInput.value); if (currentValue > 1) 
    { // optional: prevent going below 1 
        counterInput.value = currentValue - 1; } }); 
        </script>
