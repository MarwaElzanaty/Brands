@model LocalBrands.ViewModels.ProductDetailsViewModel
@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-5">
    <h1 class="text-center mb-5 fw-bold text-dark">Product Details</h1>

    <div class="row gx-lg-5">
        <div class="col-md-6 mb-4">
            @* Product Image *@
            <div class="card border-0 shadow-sm overflow-hidden mb-4 rounded-4">
                <img src="~/images/@Model.Product.PictureUrl" class="img-fluid w-100"
                     alt="@Model.Product.Name" style="object-fit: cover; height:550px !important">
            </div>

            @* Reviews Section (Shein Style - English Version) *@
            <div class="reviews-section p-4 bg-white rounded-4 shadow-sm border mt-4">

                <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                    <div>
                        <h5 class="fw-bold m-0 text-dark">Customer Reviews (@Model.Reviews.Count)</h5>
                        <div class="d-flex align-items-center mt-1">
                            <span class="fs-4 fw-bold me-2 text-dark">@Model.Product.Rating.ToString("0.0")</span>
                            <div class="text-warning small">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= Math.Round(Model.Product.Rating) ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="text-muted small" style="cursor:pointer">Review Policy <i class="bi bi-question-circle"></i></div>
                </div>

                <div class="reviews-list" style="max-height: 500px; overflow-y: auto; padding-right: 10px;">
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        @foreach (var item in Model.Reviews)
                        {
                            <div class="review-item mb-4 pb-4 border-bottom">
                                <div class="d-flex justify-content-between mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-dark rounded-circle text-white d-flex align-items-center justify-content-center me-2 fw-bold"
                                             style="width: 40px; height: 40px; font-size: 0.9rem;">
                                            @item.User.FirstName[0]
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0 text-dark" style="font-size: 0.9rem;">
                                                @item.User.FirstName @item.User.LastName
                                            </h6>
                                            <div class="text-warning" style="font-size: 0.75rem;">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="bi @(i <= item.Rating ? "bi-star-fill" : "bi-star")"></i>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <small class="text-muted" style="font-size: 0.75rem;">
                                        <i class="bi bi-calendar3 me-1"></i>@item.CreatedAt.ToString("MMM dd, yyyy")
                                    </small>
                                </div>

                                <div class="review-content ps-5">
                                    <p class="mb-2 text-dark" style="font-size: 0.95rem; line-height: 1.5; font-style: normal;">
                                        @item.Content
                                    </p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-dots fs-1 text-muted opacity-50"></i>
                            <p class="text-muted mt-3">No reviews yet. Be the first to share your thoughts!</p>
                        </div>
                    }
                </div>

                @* Add Review Form *@
                @if (Model.CanLeaveReview)
                {
                    <div class="add-review-section mt-4 p-4 bg-light rounded-4 border">
                        <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-pencil-square me-2"></i>Write a Review</h6>
                        <form asp-action="Add" asp-controller="Review" method="post">
                            <input type="hidden" name="ProductId" value="@Model.Product.Id" />

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Rating:</label>
                                <select name="Rating" class="form-select border-0 shadow-sm">
                                    <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                    <option value="4">⭐⭐⭐⭐ (Very Good)</option>
                                    <option value="3">⭐⭐⭐ (Good)</option>
                                    <option value="2">⭐⭐ (Fair)</option>
                                    <option value="1">⭐ (Poor)</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <textarea name="Content" class="form-control border-0 shadow-sm" rows="3" placeholder="Tell us about your experience..." required></textarea>
                            </div>

                            <button type="submit" class="btn btn-dark w-100 fw-bold py-2 rounded-3">Submit Review</button>
                        </form>
                    </div>
                }
            </div>
        </div>

        @* Right Section: Product Details *@
        <div class="col-md-6">
            <div class="product-details p-2">
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Home</a></li>
                        <li class="breadcrumb-item active text-dark fw-bold">@Model.Product.Brand.Name</li>
                    </ol>
                </nav>

                <h1 class="display-5 fw-bold mb-2 text-dark">@Model.Product.Name</h1>
                <p class="badge bg-dark px-3 py-2 mb-4">Local Brand: @Model.Product.Brand.Name</p>

                <div class="description-box mb-4">
                    <h6 class="fw-bold text-muted text-uppercase small border-bottom pb-2 mb-3">Description</h6>
                    <p class="text-secondary" style="line-height: 1.8; font-size: 1.1rem;">@Model.Product.Description</p>
                </div>

                <div class="d-flex align-items-center mb-4 bg-light p-3 rounded-3 border-start border-dark border-4">
                    <span class="fs-2 fw-bold text-dark me-3">@Model.Product.Price.ToString("N2") EGP</span>
                    <span class="ms-auto badge bg-white text-dark border shadow-sm p-2">
                        <i class="bi bi-fire text-danger me-1"></i>@Model.Product.SalesCount items sold
                    </span>
                </div>

                <form method="post" asp-action="UserCartCheck" asp-controller="Cart">
                    <div class="mt-5 pt-3">
                        <div class="row g-3">
                            <div class="col-4">
                                <input type="hidden" name="ProductId" value="@Model.Product.Id" />
                                <div class="input-group border border-dark rounded-3 overflow-hidden shadow-sm" style="height: 50px;">
                                    <button class="btn btn-white border-0 fw-bold" type="button" id="decrease" style="width: 35px;">-</button>
                                    <input type="text" class="form-control border-0 text-center bg-transparent fw-bold fs-5" value="1" id="counter" name="Quantity" readonly>
                                    <button class="btn btn-white border-0 fw-bold" type="button" id="increase" style="width: 35px;">+</button>
                                </div>
                            </div>
                            <div class="col-8">
                                <button type="submit" class="btn btn-dark w-100 py-2 h-100 fw-bold text-uppercase rounded-3 shadow hover-effect">
                                    <i class="bi bi-bag-plus me-2"></i>Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                @* Additional Features *@
                <div class="row mt-5 g-4 border-top pt-4">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-truck fs-3 me-3 text-muted"></i>
                            <div>
                                <h6 class="mb-0 fw-bold">Fast Delivery</h6>
                                <small class="text-muted">2-4 business days</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-arrow-repeat fs-3 me-3 text-muted"></i>
                            <div>
                                <h6 class="mb-0 fw-bold">Easy Returns</h6>
                                <small class="text-muted">Within 14 days</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .reviews-list::-webkit-scrollbar {
        width: 6px;
    }

    .reviews-list::-webkit-scrollbar-track {
        background: #f8f9fa;
    }

    .reviews-list::-webkit-scrollbar-thumb {
        background: #dee2e6;
        border-radius: 10px;
    }

        .reviews-list::-webkit-scrollbar-thumb:hover {
            background: #adb5bd;
        }

    .hover-effect:hover {
        background-color: #333 !important;
        transform: translateY(-2px);
        transition: all 0.3s ease;
    }

    .review-item {
        transition: background-color 0.2s;
    }

        .review-item:hover {
            background-color: #fafafa;
        }
</style>

<script>
    const counterInput = document.getElementById("counter");
    const increaseBtn = document.getElementById("increase");
    const decreaseBtn = document.getElementById("decrease");

    increaseBtn.addEventListener("click", () => {
        counterInput.value = parseInt(counterInput.value) + 1;
    });

    decreaseBtn.addEventListener("click", () => {
        let currentValue = parseInt(counterInput.value);
        if (currentValue > 1) {
            counterInput.value = currentValue - 1;
        }
    });
</script>
